{
  "extends": ["react-app"],
  "rules": {
    "no-unused-vars": "off",
    "no-console": "warn",
    "react-hooks/exhaustive-deps": "warn",
    "import/no-unresolved": "off",
    "no-undef": "error",
    "jsx-a11y/heading-has-content": "off"
  },
  "globals": {
    "React": "readonly"
  },
  "settings": {
    "import/resolver": {
      "node": {
        "extensions": [".js", ".jsx", ".ts", ".tsx"]
      }
    }
  }
}
